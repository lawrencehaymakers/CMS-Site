<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }}</title>
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;900&family=Barlow:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
  <!-- Favicons -->
  <link rel="icon" type="image/x-icon" href="/images/favicon.ico" />
  <link rel="icon" type="image/png" sizes="32x32" href="/images/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/images/favicon-16x16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/images/apple-touch-icon.png" />
  <!-- Netlify Identity -->
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
</head>
<body>

  <nav>
    <a class="nav-brand" href="/">
      <img src="/images/logo.png" alt="Lawrence Haymakers logo" class="nav-logo" />
      <span class="nav-wordmark">Lawrence Haymakers</span>
    </a>
    <button class="nav-toggle" aria-label="Toggle menu" onclick="this.nextElementSibling.classList.toggle('open')">
      <span></span><span></span><span></span>
    </button>
    <div class="nav-links">
      <a href="/" {% if page.url == "/" %}class="active"{% endif %}>Home</a>
      <a href="/philosophy/" {% if page.url == "/philosophy/" %}class="active"{% endif %}>Philosophy</a>
      <a href="/team/" {% if page.url == "/team/" %}class="active"{% endif %}>Team</a>
      <a href="/schedule/" {% if page.url == "/schedule/" %}class="active"{% endif %}>Schedule</a>
      <a href="/updates/" {% if page.url == "/updates/" %}class="active"{% endif %}>Updates</a>
      <a href="/packet/" {% if page.url == "/packet/" %}class="active"{% endif %}>Team Packet</a>
      <a href="/sponsors/" {% if page.url == "/sponsors/" %}class="active"{% endif %}>Sponsors</a>
      <a href="/tryouts/" class="nav-cta">Tryouts</a>
    </div>
  </nav>

  <main>
    {{ content | safe }}
  </main>

  <footer>
    {% if sponsors.list and sponsors.list.length > 0 %}
    <div class="footer-sponsors">
      <div class="footer-sponsors-label">Our Sponsors</div>
      <div class="footer-sponsors-logos">
        {% for sponsor in sponsors.list %}
        {% if sponsor.url %}<a href="{{ sponsor.url }}" target="_blank" rel="noopener" class="fs-tile{% if sponsor.dark_bg %} dark{% endif %}">{% else %}<span class="fs-tile{% if sponsor.dark_bg %} dark{% endif %}">{% endif %}
        <img src="{{ sponsor.logo }}" alt="{{ sponsor.name }}" />
        {% if sponsor.url %}</a>{% else %}</span>{% endif %}
        {% endfor %}
      </div>
    </div>
    {% endif %}
    <strong>Lawrence Haymakers Baseball</strong> &nbsp;·&nbsp; 10U &nbsp;·&nbsp; Lawrence, KS<br>
    General inquiries: <a href="mailto:Staff@LawrenceHaymakers.com">Staff@LawrenceHaymakers.com</a>
    <div style="margin-top:1rem;font-size:0.72rem;">© 2026 Lawrence Haymakers Baseball</div>
  </footer>

  <script>
    if (window.netlifyIdentity) {
      window.netlifyIdentity.on("init", user => {
        if (!user) {
          window.netlifyIdentity.on("login", () => { document.location.href = "/admin/"; });
        }
      });
    }
  </script>
</body>
</html>
