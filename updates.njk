---
layout: base.njk
title: Updates — Lawrence Haymakers
permalink: /updates/
---
<div id="fb-root"></div>
<script async defer crossorigin="anonymous" src="https://connect.facebook.net/en_US/sdk.js#xfbml=1&version=v19.0"></script>
<style>
  .updates-layout { display: grid; grid-template-columns: 1fr 380px; gap: 3rem; align-items: start; }
  .fb-wrap { position: sticky; top: 78px; }
  .fb-wrap-label { font-family: 'Barlow Condensed', sans-serif; font-size: 0.72rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--muted); margin-bottom: 0.75rem; display: flex; align-items: center; gap: 0.5rem; }
  .fb-wrap-label::after { content: ''; flex: 1; height: 1px; background: var(--rule); }
  .fb-page-container { background: white; border: 1px solid var(--rule); overflow: hidden; min-height: 500px; display: flex; align-items: center; justify-content: center; }
  .posts-list { display: flex; flex-direction: column; gap: 1.5rem; }
  .post-card { background: white; border: 1px solid var(--rule); border-top: 3px solid var(--green); padding: 1.75rem; }
  .post-meta { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem; }
  .post-tag { font-family: 'Barlow Condensed', sans-serif; font-size: 0.68rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; background: #e8f4e8; color: var(--green-dark); padding: 0.2rem 0.6rem; border-radius: 2px; }
  .post-date { font-size: 0.78rem; color: var(--muted); }
  .post-card h3 { font-family: 'Barlow Condensed', sans-serif; font-weight: 900; font-size: 1.2rem; text-transform: uppercase; letter-spacing: 0.04em; color: var(--green-dark); margin-bottom: 0.5rem; }
  .post-card p { font-size: 0.92rem; color: var(--muted); line-height: 1.65; }
  .fb-follow { margin-top: 1rem; text-align: center; }
  .fb-follow a { display: inline-flex; align-items: center; gap: 0.5rem; font-size: 0.82rem; font-weight: 600; color: #1877f2; text-decoration: none; }
  .fb-follow a:hover { text-decoration: underline; }
  @media (max-width: 820px) { .updates-layout { grid-template-columns: 1fr; } .fb-wrap { position: static; order: -1; } }
</style>

<section class="hero" style="padding-bottom:3.5rem;">
  <div class="hero-eyebrow">Lawrence Haymakers Baseball</div>
  <h1>From the <em>Dugout</em></h1>
  <p class="hero-sub">Game recaps, practice highlights, and team news from the coaching staff.</p>
</section>

<div class="section-wrap wide">
  <div class="updates-layout">
    <div>
      <div class="section-label">Team Updates</div>
      <h2 class="section-title">Latest News</h2>
      <div class="divider"></div>

      <div class="posts-list">
        {% for post in collections.posts | reverse %}
        <div class="post-card">
          <div class="post-meta">
            <span class="post-tag">{{ post.data.tag }}</span>
            <span class="post-date">{{ post.data.date | dateDisplay }}</span>
          </div>
          <h3>{{ post.data.title }}</h3>
          <p>{{ post.templateContent | safe }}</p>
        </div>
        {% endfor %}
      </div>
    </div>

    <div class="fb-wrap">
      <div class="fb-wrap-label">Follow on Facebook</div>
      <div class="fb-page-container">
        <div class="fb-page"
          data-href="https://www.facebook.com/p/Lawrence-Haymakers-Baseball-61584828301342/"
          data-tabs="timeline" data-width="360" data-height="600"
          data-small-header="true" data-adapt-container-width="true"
          data-hide-cover="false" data-show-facepile="false">
        </div>
      </div>
      <div class="fb-follow">
        <a href="https://www.facebook.com/p/Lawrence-Haymakers-Baseball-61584828301342/" target="_blank" rel="noopener">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="#1877f2"><path d="M24 12.07C24 5.41 18.63 0 12 0S0 5.41 0 12.07C0 18.1 4.39 23.1 10.13 24v-8.44H7.08v-3.49h3.04V9.41c0-3.02 1.8-4.7 4.54-4.7 1.31 0 2.68.24 2.68.24v2.97h-1.51c-1.49 0-1.95.93-1.95 1.88v2.26h3.32l-.53 3.49h-2.79V24C19.61 23.1 24 18.1 24 12.07z"/></svg>
          View on Facebook
        </a>
      </div>
    </div>
  </div>
</div>
